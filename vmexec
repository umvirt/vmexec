# Main code

# parse arguments
parser = argparse.ArgumentParser(description="VMexec script")

parser.add_argument("--server", help="Libvirt Server URI")
parser.add_argument("--vm", help="Libvirt Server URI")
parser.add_argument("--command", help="command to send")
parser.add_argument("--expect", help="expected string", default="")

args = parser.parse_args()

#print(args.command)

cmd={}

cmd["cmd"]=args.command;
if args.expect:
    cmd["expect"]=args.expect

if not(args.server):
    print (' e : Server URI is not provided')
    exit();

if not(args.vm):
    print (' e : Virtual Machine name is not provided')
    exit();


# connect to libvirt server
conn = libvirt.open(args.server)
# find VM
dom = conn.lookupByName(args.vm)
# connect to VM
stream = conn.newStream()
# Open the serial console (using 'serial0' or similar console name)
dom.openConsole(None, stream, 0)
# init rows
rows=[]

#init expect buffer
data_=" "

