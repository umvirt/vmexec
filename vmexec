if('expect' in cmd):
    print (' > : sending "' + str(cmd['cmd']) + '" and  waiting for expected response...')
    sendcommand(cmd['cmd'],cmd['expect'])
else:
    print (' > : sending "' + str(cmd['cmd']) + '"')
    sendcommand(cmd['cmd'])


